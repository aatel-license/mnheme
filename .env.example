# ═══════════════════════════════════════════════════════════════
#  MNHĒMĒ — Configurazione completa
#  Copia in .env e modifica i valori che ti servono
# ═══════════════════════════════════════════════════════════════
#
#  Compila almeno un blocco <NOME>_URL + <NOME>_MODEL.
#  La chiave API è opzionale per istanze locali (LM Studio, Ollama).
#
#  Provider attivo di default: il primo con URL+MODEL compilati
#  Per forzarne uno specifico: ACTIVE_PROVIDER=groq
#
# ═══════════════════════════════════════════════════════════════
# kokoro o 
# default cambiato da pyttsx3 a kokoro
TTS_ENGINE    = kokoro         
# qualsiasi voce Kokoro
TTS_VOICE     = af_bella        
# a=American English, b=British English  # pip install misaki[en<] a='American English'<, b='British English<' # espeak-n<g e='es'<, f='fr-fr'<, h='hi'<, i='it'<, p='pt-br<' # pip install misaki[ja<] j='Japanese', # pip install misaki[zh] z='Mandarin Chinese',
KOKORO_LANG   = i               
KOKORO_SPEED  = 1.0
KOKORO_SAMPLE_RATE = 24000
# Provider da usare (lascia vuoto per usare il primo disponibile)
# ── Provider & Configurazione Globale ────────────────────────────

# Provider da usare (lascia vuoto per usare il primo disponibile)
ACTIVE_PROVIDER=lm-studio

# Temperatura default per tutti i provider
TEMPERATURE=0.3

# Fallback a cascata se true (prova tutti i provider in ordine)
USE_MULTI_PROVIDER=false

# ── Database MNHĒMĒ ───────────────────────────────────────────────

MNHEME_DB_PATH=mnheme.mnheme

# Directory file multimediali (vuoto = <db_stem>_files/)
MNHEME_FILES_DIR=

# true se vuoi i tool brain_*
BRAIN_ENABLED=true

# Quanti ricordi passare come contesto al modello in conversazione
MAX_CONTEXT_MEMORIES=8

# Risultati per ogni ricerca full-text nel RAG
RAG_SEARCH_LIMIT=8

# Ultimi N ricordi sempre inclusi nel contesto (per continuità temporale)
RAG_RECENT_LIMIT=5

# Quanti turn della conversazione tenere in memoria
HISTORY_LENGTH=12


# ── LM Studio (locale) ───────────────────────────────────────────

LM_STUDIO_URL=http://localhost:1234/v1/chat/completions
LM_STUDIO_URL_LIVE=http://localhost:1234/v1
LM_STUDIO_MODEL=gemma4-vision
LM_STUDIO_API_KEY=
LM_STUDIO_RPM=60

# Modello per la conversazione (vuoto = stesso di LM_STUDIO_MODEL)
# Puoi usare un modello più leggero/veloce per la chat
LM_STUDIO_CHAT_MODEL=

# Temperature specifiche per percezione e chat (sovrascrivono TEMPERATURE)
LM_TEMPERATURE_PERCEPTION=0.4
LM_TEMPERATURE_CHAT=0.7

# Lunghezza massima risposta in token
# Lunghezza massima risposta in token
LM_MAX_TOKENS_PERCEPTION=5120
LM_MAX_TOKENS_CHAT=5120

# ── Ollama / qualsiasi server OpenAI-compatibile (locale) ────────

LOCAL_LLM_URL=http://localhost:11434/v1/chat/completions
LOCAL_LLM_MODEL=llama3
LOCAL_LLM_API_KEY=
LOCAL_LLM_RPM=60


# ── Whisper ───────────────────────────────────────────────────────
# Modello: tiny (veloce, meno accurato) → large (lento, accurato)
# Consigliato: base o small per uso in tempo reale
WHISPER_MODEL=base

# Lingua trascrizione quando parli tu (conversazione)
CONVERSATION_LANGUAGE=it

# Lingua audio TV/ambiente (vuoto = rilevamento automatico)
PERCEPTION_LANGUAGE=


# ── Percezione ────────────────────────────────────────────────────

# Secondi tra un ciclo percettivo e il successivo
PERCEPTION_INTERVAL=20

# Secondi di audio registrato per ogni ciclo percettivo
AUDIO_DURATION=10

# Indice fotocamera (0 = prima fotocamera, 1 = seconda, ecc.)
# Usa --list-devices per vedere le fotocamere disponibili
CAMERA_INDEX=0

# Risoluzione frame inviato al modello vision
FRAME_WIDTH=1280
FRAME_HEIGHT=720

# Qualità JPEG del frame (1-100)
# Il frame viene inviato al modello e poi SCARTATO — non salvato
JPEG_QUALITY=85

# Frequenza campionamento audio (Whisper richiede 16000)
AUDIO_SAMPLE_RATE=16000


# ── TTS (Text-to-Speech) ──────────────────────────────────────────
# Motore TTS: pyttsx3 | edge-tts | none
TTS_ENGINE=pyttsx3

# Nome voce pyttsx3 (vuoto = prima voce italiana disponibile)
# Usa python -c "import pyttsx3; e=pyttsx3.init(); [print(v.name) for v in e.getProperty('voices')]"
TTS_VOICE=

# Velocità parlato pyttsx3 (parole al minuto, default 150)
TTS_RATE=150

# Voce Microsoft edge-tts (richiede: pip install edge-tts pygame)
# Voci italiane disponibili: it-IT-ElsaNeural | it-IT-IsabellaNeural | it-IT-DiegoNeural
EDGE_TTS_VOICE=it-IT-ElsaNeural


# ═══════════════════════════════════════════════════════════════
#  PROVIDER LLM CLOUD
# ═══════════════════════════════════════════════════════════════

# ── Anthropic — Claude (formato nativo, rilevato automaticamente) ─

ANTHROPIC_URL=https://api.anthropic.com/v1/messages
ANTHROPIC_MODEL=claude-opus-4-5
ANTHROPIC_API_KEY=
ANTHROPIC_RPM=5

# ── Groq ─────────────────────────────────────────────────────────

GROQ_URL=https://api.groq.com/openai/v1/chat/completions
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_API_KEY=
GROQ_RPM=30

# ── SambaNova ────────────────────────────────────────────────────

SAMBANOVA_URL=https://api.sambanova.ai/v1/chat/completions
SAMBANOVA_MODEL=Meta-Llama-3.3-70B-Instruct
SAMBANOVA_API_KEY=
SAMBANOVA_RPM=12

# ── OpenRouter ───────────────────────────────────────────────────

OPENROUTER_URL=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_MODEL=meta-llama/llama-3.1-405b
OPENROUTER_API_KEY=
OPENROUTER_RPM=10

# ── Google AI Studio ─────────────────────────────────────────────

GOOGLE_AI_STUDIO_URL=https://generativelanguage.googleapis.com/v1beta/openai/chat/completions
GOOGLE_AI_STUDIO_MODEL=gemini-1.5-pro
GOOGLE_AI_STUDIO_API_KEY=
GOOGLE_AI_STUDIO_RPM=15

# ── Mistral ──────────────────────────────────────────────────────

MISTRAL_URL=https://api.mistral.ai/v1/chat/completions
